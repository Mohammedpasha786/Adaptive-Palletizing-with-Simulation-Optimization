%   Simulates a conveyor belt feeding boxes of unknown size one at a time.
%   The PerceptionBuffer accumulates detections until the threshold is
%   reached, then flushes the batch for layout optimization.
%
%   Usage:
%       cd <repo root>
%       run scripts/run_realtime_demo.m

clear; clc; close all;

repoRoot = fileparts(fileparts(mfilename('fullpath')));
addpath(genpath(fullfile(repoRoot, 'src')));
addpath(genpath(fullfile(repoRoot, 'data')));

fprintf('=== Real-Time (Conveyor) Demo ===\n\n');

THRESHOLD  = 8;
SEED       = 42;

fprintf('Simulating conveyor feed (threshold = %d boxes, seed = %d) ...\n\n', ...
    THRESHOLD, SEED);

buf = PerceptionBuffer('ReadyThreshold', THRESHOLD);

for arrival = 1:THRESHOLD
    box = simulateBoxDetection(1, 'Seed', SEED + arrival);
    buf.addBox(box);
    fprintf('  Conveyor arrival %2d: %s  [%.0f x %.0f x %.0f mm,  %.2f kg]\n', ...
        arrival, box.id, box.length, box.width, box.height, box.weight);
end

fprintf('\nBuffer ready (%d boxes). Flushing for optimization ...\n', buf.count());
boxes = buf.flush();

%% Run the pipeline with the flushed batch
pallet = struct('length', 1200, 'width', 800, 'maxHeight', 1200, 'maxWeight', 1000);
[layout, info] = greedyLayoutHeuristic(boxes, pallet);

fprintf('\n--- Layout result ---\n');
fprintf('  Utilisation : %.1f%%\n', 100 * info.utilization);
fprintf('  Placed      : %d / %d\n', sum(layout.placed), height(layout));

[isValid, issues] = checkLayoutCollisions(layout, pallet);
if isValid
    fprintf('  Collision check: OK\n');
else
    fprintf('  Collision issues: %s\n', strjoin(issues, ' | '));
end

plotPalletLayout(layout, pallet, 'Title', ...
    sprintf('Real-time mode layout (%d boxes, greedy)', THRESHOLD));

fprintf('\nReal-time demo complete.\n');
