classdef RTDEInterface < handle
    %RTDEINTERFACE Send motion commands to URSim or a physical UR e-series robot.
    %
    %   rtde = RTDEInterface()
    %   rtde = RTDEInterface('Mode', 'mock')
    %   rtde = RTDEInterface('Mode', 'urscript', 'Host', '127.0.0.1', 'Port', 30002)
    %
    %   This class provides a minimal, dependency-light wrapper for
    %   driving a Universal Robots e-series robot (or URSim) from the
    %   adaptive palletizing pipeline. Two modes are supported:
    %
    %     'mock'     - (default) no network connection is made. Every
    %                   command is recorded in CommandLog and the
    %                   "actual" TCP pose is updated immediately to the
    %                   commanded pose. Use this for development, unit
    %                   tests, and CI, where no robot/URSim is available.
    %
    %     'urscript' - opens a TCP connection to the robot controller's
    %                   primary interface (default port 30002) and sends
    %                   URScript program snippets (e.g., movej/movel) as
    %                   plain text. This is the simplest "minimal code
    %                   changes" path from simulation to hardware
    %                   described in docs/PROJECT_PROPOSAL.md (Step 6).
    %
    %   NOTE ON FULL RTDE: The Real-Time Data Exchange (RTDE) protocol
    %   (typically port 30004) is a binary, recipe-based protocol used
    %   for high-frequency state streaming and is not implemented here.
    %   For high-frequency feedback (e.g., for the predictive maintenance
    %   module), use MATLAB's UR support package or a dedicated RTDE
    %   client library and feed its output into RUNPALLETIZINGCONTROLLOOP.
    %
    %   Example:
    %       rtde = RTDEInterface();           % mock mode
    %       rtde.connect();
    %       rtde.moveLinear([400 200 300 0 pi 0]);  % [x y z rx ry rz] mm/rad
    %       pose = rtde.getActualTCPPose();
    %       rtde.disconnect();

    properties
        Mode (1,1) string {mustBeMember(Mode, ["mock","urscript"])} = "mock"
        Host (1,1) string = "127.0.0.1"
        Port (1,1) double = 30002
        ConnectTimeout (1,1) double = 5
        Acceleration (1,1) double = 1.2  % m/s^2, used in movel/movej commands
        Velocity (1,1) double = 0.25     % m/s (movel) or rad/s (movej)
    end

    properties (SetAccess = private)
        Connected (1,1) logical = false
        CommandLog (:,1) string = strings(0,1)
        LastTCPPose (1,6) double = [0 0 0 0 0 0] % [x y z rx ry rz], meters/rad
    end

    properties (Access = private)
        TcpClientObj = []
    end

    methods
        function obj = RTDEInterface(options)
            arguments
                options.Mode (1,1) string {mustBeMember(options.Mode, ["mock","urscript"])} = "mock"
                options.Host (1,1) string = "127.0.0.1"
                options.Port (1,1) double = 30002
                options.ConnectTimeout (1,1) double = 5
            end
            obj.Mode = options.Mode;
            obj.Host = options.Host;
            obj.Port = options.Port;
            obj.ConnectTimeout = options.ConnectTimeout;
        end

        function connect(obj)
            %CONNECT Open the connection (no-op in mock mode).
            if obj.Mode == "mock"
                obj.Connected = true;
                return
            end

            try
                obj.TcpClientObj = tcpclient(obj.Host, obj.Port, ...
                    'Timeout', obj.ConnectTimeout);
                obj.Connected = true;
            catch ME
                error('RTDEInterface:ConnectionFailed', ...
                    'Could not connect to %s:%d (%s). Use Mode="mock" for offline development.', ...
                    obj.Host, obj.Port, ME.message);
            end
        end

        function disconnect(obj)
            %DISCONNECT Close the connection (no-op in mock mode).
            if obj.Mode == "urscript" && ~isempty(obj.TcpClientObj)
                clear obj.TcpClientObj
                obj.TcpClientObj = [];
            end
            obj.Connected = false;
        end

        function moveLinear(obj, pose)
            %MOVELINEAR Move the TCP to POSE = [x y z rx ry rz] (mm, rad)
            %via a URScript movel command.
            arguments
                obj
                pose (1,6) double
            end
            poseM = pose;
            poseM(1:3) = poseM(1:3) / 1000; % mm -> m for URScript

            cmd = sprintf('movel(p[%.6f,%.6f,%.6f,%.6f,%.6f,%.6f], a=%.3f, v=%.3f)\n', ...
                poseM(1), poseM(2), poseM(3), poseM(4), poseM(5), poseM(6), ...
                obj.Acceleration, obj.Velocity);

            obj.sendCommand(cmd);
            obj.LastTCPPose = poseM;
        end

        function moveJoint(obj, q)
            %MOVEJOINT Move to joint configuration Q (1x6, rad) via a
            %URScript movej command.
            arguments
                obj
                q (1,6) double
            end
            cmd = sprintf('movej([%.6f,%.6f,%.6f,%.6f,%.6f,%.6f], a=%.3f, v=%.3f)\n', ...
                q(1), q(2), q(3), q(4), q(5), q(6), obj.Acceleration, obj.Velocity);

            obj.sendCommand(cmd);
        end

        function pose = getActualTCPPose(obj)
            %GETACTUALTCPPOSE Return the last commanded TCP pose
            %(meters, rad). In 'mock' mode this is simply the most
            %recent MOVELINEAR target. In 'urscript' mode, true feedback
            %requires an RTDE state-streaming connection (see class
            %notes); this method still returns the last commanded pose
            %as a best-effort placeholder.
            pose = obj.LastTCPPose;
        end

        function sendBoxPlacement(obj, layoutRow, options)
            %SENDBOXPLACEMENT Move to the approach point above a placed
            %box, then descend onto it. LAYOUTROW must be a one-row table
            %with the columns produced by SHELFPACK (x, y, z,
            %placedLength, placedWidth, height).
            arguments
                obj
                layoutRow table
                options.ApproachHeight (1,1) double = 150
                options.Orientation (1,3) double = [0, pi, 0]
            end

            if height(layoutRow) ~= 1
                error('RTDEInterface:InvalidInput', ...
                    'sendBoxPlacement expects a single-row layout table.');
            end

            cx = layoutRow.x + layoutRow.placedLength/2;
            cy = layoutRow.y + layoutRow.placedWidth/2;
            cz = layoutRow.z + layoutRow.height;

            approachPose = [cx, cy, cz + options.ApproachHeight, options.Orientation];
            placePose    = [cx, cy, cz, options.Orientation];

            obj.moveLinear(approachPose);
            obj.moveLinear(placePose);
        end
    end

    methods (Access = private)
        function sendCommand(obj, cmd)
            obj.CommandLog(end+1,1) = string(cmd);

            if obj.Mode == "mock"
                return
            end

            if ~obj.Connected || isempty(obj.TcpClientObj)
                error('RTDEInterface:NotConnected', ...
                    'Call connect() before sending commands in "urscript" mode.');
            end

            write(obj.TcpClientObj, uint8(cmd));
        end
    end
end
